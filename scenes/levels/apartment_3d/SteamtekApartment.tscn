[node name="SteamtekApartment" type="Node3D" unique_id=195688292]
editor_description = "Production opening apartment: wake beside the bed (north wall), read the note, cross the open south-east living area to the storage crate, equip a weapon, exit through the door on the north wall's east end. The east/south sides are deliberately open (no walls) so the camera, looking in from the south-east, has a clear view of the room."
