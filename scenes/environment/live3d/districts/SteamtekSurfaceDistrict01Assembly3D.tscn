[node name="SteamtekSurfaceDistrict01Assembly3D" type="Node3D" groups=["steamtek_live3d_district"]]
editor_description = "Canonical sparse opening route for Surface District 01: leave the Player Apartment after finding the note, traverse Rain Alley and Main Street to The Lantern, then unlock the Side Street/Basement route to the Maintenance Lift and underground city. Temporary contract geometry only."
metadata/status = "surface_district_blueprint_v1_blockout"
metadata/unit_contract = "1_godot_unit_equals_1_meter"
metadata/module_system = "live3d_meter_v1"
metadata/snap_grid_m = 2.4
metadata/route_topology = "player_apartment_to_rain_alley_to_split_to_main_street_to_lantern_then_side_street_to_basement_to_maintenance_lift"
metadata/opening_quest_flow = "wake_in_apartment_find_note_reach_lantern_receive_underground_quest_reach_maintenance_lift"
metadata/tutorial_pillars = "quests_movement_combat_crafting_exploration_interactables"
metadata/population_contract = "sparse_surface; meaningful NPC concentration belongs inside The Lantern; exterior gameplay relies on spaces, encounters, salvage, and interactables rather than crowds"
metadata/north_axis = "+Z"
metadata/opening_travel_axis = "+X_west_to_east"
metadata/building_rotation_contract = "Yaw only: 0, 90, 180, or 270 degrees; never negative-scale mirror"
metadata/art_status = "temporary_geometry_and_materials_final_art_replacement_ready"

